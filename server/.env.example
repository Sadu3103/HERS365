# HERS365 — Local Dev Environment
# Copy this file: cp .env.example .env
# Everything below works out of the box for local dev.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/hers365

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=hers365-local-dev-secret-do-not-use-in-production
# [D-05] Short-lived access token; clients silently renew via /api/auth/refresh.
JWT_EXPIRES=15m
# [D-05] How long the refresh-token cookie stays valid before re-login is needed.
REFRESH_TOKEN_TTL_DAYS=30
SESSION_SECRET=hers365-local-session-secret

# ── Redis (optional) ────────────────────────────────────────────────────────
# Opt-in: when set, enables the server-side logout token blocklist (D-06).
# Leave unset for local dev — the blocklist degrades gracefully without it.
# REDIS_URL=redis://localhost:6379

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional: only needed if working on these features ──────────────────────

# Payments (Stripe) — skip unless working on subscription/checkout flows
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# AI features (feed bot, training recommendations)
# OPENAI_API_KEY=sk-...

# Google OAuth — not needed, email/password login works without it
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
