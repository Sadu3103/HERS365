# HERS365 — Local Dev Environment
# Copy this file: cp .env.example .env
# Everything below works out of the box for local dev.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/hers365

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=hers365-local-dev-secret-do-not-use-in-production
# [D-05] Short-lived access token; clients silently renew via /api/auth/refresh.
JWT_EXPIRES=15m
# [D-05] How long the refresh-token cookie stays valid before re-login is needed.
REFRESH_TOKEN_TTL_DAYS=30
SESSION_SECRET=hers365-local-session-secret

# ── Redis (optional) ────────────────────────────────────────────────────────
# Opt-in: when set, enables the server-side logout token blocklist (D-06).
# Leave unset for local dev — the blocklist degrades gracefully without it.
# REDIS_URL=redis://localhost:6379

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional: only needed if working on these features ──────────────────────

# Payments (Stripe) — skip unless working on subscription/checkout flows
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# Media storage (S3 + CloudFront) — skip unless working on uploads
# [D-08] Photos and game film use SEPARATE buckets + CDNs. VIDEO_* fall back to
# the photo bucket/CDN if unset. See docs/VIDEO-STORAGE.md.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=hers365-media               # profile photos / general media
# CLOUDFRONT_URL=https://dxxxx.cloudfront.net
# VIDEO_BUCKET=hers365-film             # game film, separate bucket
# VIDEO_CDN_URL=https://dyyyy.cloudfront.net
# MAX_VIDEO_BYTES=524288000             # 500MB upload cap
# VIDEO_UPLOAD_TTL_SECONDS=21600        # 6h presign TTL for large uploads

# AI features (feed bot, training recommendations) — still uses OpenAI for now.
# OPENAI_API_KEY=sk-...

# Content moderation (coach↔athlete messaging) — Claude Haiku 4.5 via the
# Anthropic API. REQUIRED in production: without it, moderation fails closed
# and messages are rejected with moderation_unavailable. Replaces the old
# OPENAI_API_KEY moderation path.
# ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — not needed, email/password login works without it
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Instant Login (Demo) — POSITIVE non-prod assertion, fails closed.
# Requires BOTH (a) APP_ENV (or NODE_ENV) exactly 'development' or 'test',
# AND (b) DEMO_ENABLED=true. Unset / 'production' / anything else → gate
# rejects with 403. The dev script (npm run dev:core) already sets
# APP_ENV=development, so locally you only need DEMO_ENABLED=true.
# DEMO_ENABLED=true
# APP_ENV=development

# GitHub OAuth (Auth page)
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
# FRONTEND_URL=http://localhost:5173

# Password reset emails
# RESEND_API_KEY=...
