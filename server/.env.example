# HERS365 — Local Dev Environment
# Copy this file: cp .env.example .env
# Everything below works out of the box for local dev.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/hers365

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=hers365-local-dev-secret-do-not-use-in-production
JWT_EXPIRES=7d
SESSION_SECRET=hers365-local-session-secret

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional: only needed if working on these features ──────────────────────

# Payments (Stripe) — skip unless working on subscription/checkout flows
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# AI features (feed bot, training recommendations) — still uses OpenAI for now.
# OPENAI_API_KEY=sk-...

# Content moderation (coach↔athlete messaging) — Claude Haiku 4.5 via the
# Anthropic API. REQUIRED in production: without it, moderation fails closed
# and messages are rejected with moderation_unavailable. Replaces the old
# OPENAI_API_KEY moderation path.
# ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — not needed, email/password login works without it
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Instant Login (Demo) — POSITIVE non-prod assertion, fails closed.
# Requires BOTH (a) APP_ENV (or NODE_ENV) exactly 'development' or 'test',
# AND (b) DEMO_ENABLED=true. Unset / 'production' / anything else → gate
# rejects with 403. The dev script (npm run dev:core) already sets
# APP_ENV=development, so locally you only need DEMO_ENABLED=true.
# DEMO_ENABLED=true
# APP_ENV=development
