# HERS365 — Local Dev Environment
# Copy this file: cp .env.example .env
# Everything below works out of the box for local dev.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost:5432/hers365

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=hers365-local-dev-secret-do-not-use-in-production
JWT_EXPIRES=7d
SESSION_SECRET=hers365-local-session-secret

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional: only needed if working on these features ──────────────────────

# Payments (Stripe) — skip unless working on subscription/checkout flows.
# [D-09] Set PAYMENTS_ENABLED=false to run the server without Stripe in dev.
# When true (the default), all three keys below are REQUIRED at startup —
# the server exits if any is missing, instead of failing later at checkout.
# PAYMENTS_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_...      # required when PAYMENTS_ENABLED is not false
# STRIPE_WEBHOOK_SECRET=whsec_...    # required when PAYMENTS_ENABLED is not false
# STRIPE_PRO_PRICE_ID=price_...      # required when PAYMENTS_ENABLED is not false

# AI features (feed bot, training recommendations)
# OPENAI_API_KEY=sk-...

# Google OAuth — not needed, email/password login works without it
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
