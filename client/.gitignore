# Capacitor iOS — build artifacts and user-local state only.
# The native project (ios/App, ios/capacitor-cordova-ios-plugins, etc.) IS
# committed so the App Store pipeline reproduces; the dirs below are
# regenerated by `npm run mobile:build` or by Xcode and should not be tracked.
ios/App/App/public
ios/App/build
ios/DerivedData
ios/App/App.xcodeproj/xcuserdata
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata
ios/App/App.xcworkspace/xcuserdata
*.xcuserstate
