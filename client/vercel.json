{
  "rewrites": [
    {
      "source": "/health-api",
      "destination": "https://hers365-api-production.up.railway.app/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://hers365-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
