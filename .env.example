# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Session Configuration
SESSION_SECRET=your_session_secret_key

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173# Server
NODE_ENV=production
PORT=10000

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars
SESSION_SECRET=your_session_secret_min_32_chars

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — set to the Render static site URL in production
CORS_ORIGIN=https://hers365-client.onrender.com

# OAuth — Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://hers365-api.onrender.com/api/auth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://hers365-api.onrender.com/api/auth/github/callback

# OpenAI
OPENAI_API_KEY=sk-...

# Client (Vite — prefix VITE_ so they're bundled)
VITE_API_URL=https://hers365-api.onrender.com
